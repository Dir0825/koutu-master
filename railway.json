{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPkgs": ["python39", "python39Packages.pip", "gcc", "libglib2.dev", "liblcms2-dev", "openjpeg-dev", "zlib-dev", "libpng-dev", "libwebp-dev", "tcl", "tk"]
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
